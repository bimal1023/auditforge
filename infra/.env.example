# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# External APIs
TAVILY_API_KEY=tvly-...
# SEC EDGAR requires a User-Agent: "CompanyName AdminContact@example.com"
SEC_EDGAR_USER_AGENT=AuditForge bimalkumal2004@gmail.com

# Database
# Local dev: use localhost. Docker (docker-compose): use service names below.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auditforge
REDIS_URL=redis://localhost:6379/0
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/auditforge
# REDIS_URL=redis://redis:6379/0

# Optional model overrides (defaults shown)
ORCHESTRATOR_MODEL=claude-opus-4-7
SPECIALIST_MODEL=claude-sonnet-4-6

# Auth (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production

# CORS — comma-separated, add your production domain here
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (used by docker-compose and Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
