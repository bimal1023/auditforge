# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# External APIs
TAVILY_API_KEY=tvly-...
# SEC EDGAR requires a User-Agent: "CompanyName AdminContact@company.com"
SEC_EDGAR_USER_AGENT=Arthvion contact@yourcompany.com

# ── Additional data sources (all optional — agents degrade gracefully if blank) ──
# Financial Modeling Prep (clean fundamentals/ratios). Free tier 250 req/day:
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# FRED — St. Louis Fed macro/economic data (used by the Market agent).
# Free key, issued instantly: https://fredaccount.stlouisfed.org/apikey
FRED_API_KEY=
# CourtListener / RECAP — real US court dockets (used by the Legal agent).
# Works anonymously but rate-limited; a free token raises limits:
# https://www.courtlistener.com/help/api/rest/
COURTLISTENER_API_TOKEN=
# OpenSanctions — sanctions / PEP / watchlist screening (used by the Legal agent).
# Free tier available: https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arthvion
REDIS_URL=redis://:changeme@localhost:6379/0
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/arthvion
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Redis password (must match what Redis is started with)
REDIS_PASSWORD=changeme

# Optional model overrides (defaults shown)
ORCHESTRATOR_MODEL=claude-opus-4-7
SPECIALIST_MODEL=claude-sonnet-4-6

# Auth — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED — the app will refuse to start with the placeholder value
SECRET_KEY=REPLACE_THIS_WITH_OUTPUT_OF_ABOVE_COMMAND

# CORS — comma-separated, add your production domain here
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Backend URL used by the Next.js SSE proxy (server-side only, not exposed to browser)
API_URL=http://localhost:8000

# Frontend (used by docker-compose)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Email (Resend) — used for password reset + welcome emails.
# Get your key at https://resend.com/api-keys. Leave blank to disable email
# entirely in development (auth endpoints still succeed, just don't send).
RESEND_API_KEY=
# Must be a sender on a domain verified in your Resend dashboard.
# Use the fallback below for local dev — it sends from Resend's onboarding domain.
RESEND_FROM_EMAIL=Arthvion <onboarding@resend.dev>

# Public URL of the frontend, used to build links inside email bodies
# (e.g. password reset CTAs). Must include the protocol.
APP_URL=http://localhost:3000

# Stripe billing — get keys at https://dashboard.stripe.com/test/apikeys
# Use sk_test_* in dev; sk_live_* in production (never commit live keys).
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret. For local dev, run `stripe listen --forward-to
# localhost:8000/api/v1/billing/webhook` and copy the printed `whsec_...`.
# For production, copy from the Webhooks page in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID of the Desk plan ($399/mo, created via Stripe catalog).
STRIPE_DESK_PRICE_ID=price_...
# Price ID of the one-time "extra memo credit" top-up (one-time price billed
# per unit — checkout quantity == credits purchased). Lets Desk/Firm customers
# buy overage mid-cycle without changing plan. Leave blank to disable top-ups.
STRIPE_TOPUP_PRICE_ID=price_...
# Trial days. 0 = charge immediately on Desk subscription start (recommended;
# the Solo free tier acts as the trial). Set to a positive integer only if
# you have data showing >50% trial→paid conversion.
STRIPE_TRIAL_DAYS=0

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
